# ─── Backend Environment Variables ───
# Copy this file to .env and fill in your values

SECRET_KEY=your-secret-key-here
DEBUG=false

# Supabase PostgreSQL (use the Transaction Pooler connection string)
SUPABASE_DB_URL=postgresql://postgres.[project-id]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Supabase Project (for storage/auth client)
SUPABASE_PROJECT_URL=https://[project-id].supabase.co
SUPABASE_API_KEY=your-supabase-anon-key
